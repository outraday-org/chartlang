{
    "name": "chartlang",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "packageManager": "pnpm@9.12.0",
    "engines": { "node": ">=20" },
    "scripts": {
        "build": "pnpm -r --parallel build",
        "typecheck": "pnpm -r --parallel typecheck",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "bench": "vitest bench",
        "bench:ci": "vitest bench --run",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "check": "pnpm format:check && pnpm lint && pnpm build && pnpm typecheck && pnpm test && pnpm docs:check && pnpm docs:gate && pnpm readme:check && pnpm conformance",
        "conformance": "pnpm tsx scripts/run-conformance.ts",
        "conformance:report": "pnpm tsx scripts/run-conformance.ts --report",
        "docs:check": "pnpm tsx scripts/docs-check.ts",
        "docs:generate": "pnpm chartlang docs",
        "docs:gate": "pnpm tsx scripts/docs-gate.ts",
        "gen-hover-registry": "pnpm tsx scripts/gen-hover-registry.ts",
        "hover:check": "pnpm gen-hover-registry -- --check",
        "docs:build": "vitepress build docs",
        "readme:check": "pnpm tsx scripts/readme-check.ts",
        "coverage:report": "pnpm tsx scripts/coverage-merge.ts",
        "scaffold": "pnpm tsx scripts/scaffold.ts",
        "test:scripts": "vitest run -c scripts/vitest.config.ts",
        "chartlang": "tsx packages/cli/src/bin.ts",
        "changeset": "changeset",
        "release": "pnpm build && changeset publish",
        "publish:release": "pnpm release"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.0",
        "@changesets/cli": "^2.27.0",
        "@invinite-org/chartlang-cli": "workspace:*",
        "@invinite-org/chartlang-compiler": "workspace:*",
        "@vitest/coverage-v8": "^2.1.0",
        "expect-type": "^1.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0",
        "vitepress": "^1.4.0",
        "vitest": "^2.1.0"
    }
}
