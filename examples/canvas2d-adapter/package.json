{
    "name": "chartlang-example-canvas2d-adapter",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "description": "Reference adapter — renders to a <canvas> element",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
