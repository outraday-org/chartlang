# Copy to `.env` and fill in. `.env` is git-ignored; this sample is committed.

# Local SQLite file (saved scripts + EODData cache + daily quota). The DB
# auto-creates, migrates, and seeds on first boot — no manual step.
DATABASE_URL=file:./data/starter.db

# EODData API key — free tier: 100 calls/day, 10 calls/min, daily EOD, US
# symbols (AMEX / NASDAQ / NYSE / OTCBB). Register at
# https://eoddata.com/myaccount/api.aspx . Used by the server-only EODData
# layer; the key never reaches the client bundle. The layer caches every
# (symbol, range) in SQLite and counts a per-UTC-day quota, so a re-open /
# re-compile costs zero API calls.
EODDATA_API_KEY=

# Optional overrides (defaults shown). Base URL is resolved from the live
# OpenAPI spec https://api.eoddata.com/openapi/v1.json (auth = `ApiKey` query
# param). EODDATA_DAILY_LIMIT lets you tighten the free-tier guard.
# EODDATA_BASE_URL=https://api.eoddata.com/v1
# EODDATA_DAILY_LIMIT=100
