{
    "name": "chartlang-react-starter",
    "private": true,
    "version": "0.0.8",
    "type": "module",
    "license": "MIT",
    "description": "chartlang starter — clonable TanStack Start + shadcn (Base UI default) app.",
    "scripts": {
        "dev": "vite dev --port 3100",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "lint": "biome lint .",
        "typecheck": "tsc --noEmit",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "e2e": "playwright test",
        "e2e:install": "playwright install --with-deps chromium"
    },
    "dependencies": {
        "@base-ui/react": "^1.6.0",
        "@codemirror/language": "^6",
        "@codemirror/state": "^6",
        "@codemirror/view": "^6",
        "@invinite-org/chartlang-adapter-kit": "workspace:*",
        "@invinite-org/chartlang-core": "workspace:*",
        "@invinite-org/chartlang-editor": "workspace:*",
        "@invinite-org/chartlang-host-worker": "workspace:*",
        "@invinite-org/chartlang-language-service": "workspace:*",
        "@lezer/highlight": "^1",
        "@tailwindcss/vite": "^4",
        "chartlang-example-canvas2d-adapter": "workspace:*",
        "chartlang-example-webgl-adapter": "workspace:*",
        "better-sqlite3": "^12.11.1",
        "drizzle-orm": "^0.45.2",
        "@tanstack/react-devtools": "latest",
        "@tanstack/react-router": "latest",
        "@tanstack/react-router-devtools": "latest",
        "@tanstack/react-router-ssr-query": "latest",
        "@tanstack/react-start": "latest",
        "@tanstack/router-plugin": "latest",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "lucide-react": "^1.18.0",
        "next-themes": "^0.4.6",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-resizable-panels": "^3.0.6",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4",
        "tw-animate-css": "^1.0.0"
    },
    "devDependencies": {
        "@invinite-org/chartlang-compiler": "workspace:*",
        "@playwright/test": "^1.45.0",
        "@tanstack/devtools-vite": "latest",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^22",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^6",
        "chartlang-example-echarts-adapter": "workspace:*",
        "chartlang-example-konva-adapter": "workspace:*",
        "chartlang-example-lightweight-charts-adapter": "workspace:*",
        "chartlang-example-uplot-adapter": "workspace:*",
        "drizzle-kit": "^0.31.10",
        "echarts": "^5",
        "esbuild": "^0.24.0",
        "jsdom": "^28",
        "konva": "^9",
        "lightweight-charts": "^5",
        "typescript": "^6",
        "uplot": "^1",
        "vite": "^8",
        "vitest": "^4"
    },
    "engines": {
        "node": ">=22"
    }
