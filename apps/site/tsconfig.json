{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "verbatimModuleSyntax": false,
        "allowImportingTsExtensions": true,
        "noUncheckedSideEffectImports": true,
        "types": ["vite/client"],
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src/**/*", "vite.config.ts"]
}
