{
    "name": "@invinite-org/chartlang-conformance",
    "version": "1.2.1",
    "type": "module",
    "license": "MIT",
    "description": "Adapter conformance test suite",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": ["dist", "fixtures", "README.md", "CHANGELOG.md", "LICENSE"],
    "dependencies": {
        "@invinite-org/chartlang-adapter-kit": "workspace:^",
        "@invinite-org/chartlang-compiler": "workspace:^",
        "@invinite-org/chartlang-core": "workspace:^",
        "@invinite-org/chartlang-pine-converter": "workspace:^",
        "@invinite-org/chartlang-runtime": "workspace:^"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "fast-check": "^3.20.0"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run --coverage"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "engines": {
        "node": ">=20"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/outraday-org/chartlang.git",
        "directory": "packages/conformance"
    }
}
