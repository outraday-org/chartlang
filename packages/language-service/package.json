{
    "name": "@invinite-org/chartlang-language-service",
    "version": "1.5.2",
    "type": "module",
    "license": "MIT",
    "description": "Headless editor intelligence — hover, completions, diagnostics, signature help",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run --coverage"
    },
    "dependencies": {
        "@invinite-org/chartlang-adapter-kit": "workspace:*",
        "@invinite-org/chartlang-compiler": "workspace:*",
        "@invinite-org/chartlang-core": "workspace:*",
        "typescript": "^5.6.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "engines": {
        "node": ">=20"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/outraday-org/chartlang.git",
        "directory": "packages/language-service"
    }
