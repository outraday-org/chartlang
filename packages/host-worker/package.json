{
    "name": "@invinite-org/chartlang-host-worker",
    "version": "1.3.0",
    "type": "module",
    "license": "MIT",
    "description": "Web Worker ScriptHost for the browser",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./idb": {
            "types": "./dist/idb.d.ts",
            "import": "./dist/idb.js"
        },
        "./worker-boot": {
            "types": "./dist/worker-boot.d.ts",
            "import": "./dist/worker-boot.js"
        }
    },
    "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
    "scripts": {
        "build": "tsc -p tsconfig.json && pnpm tsx ./scripts/buildWorkerBoot.ts",
        "build:worker-boot": "pnpm tsx ./scripts/buildWorkerBoot.ts",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run --coverage",
        "bench": "vitest bench --run"
    },
    "dependencies": {
        "@invinite-org/chartlang-adapter-kit": "workspace:^",
        "@invinite-org/chartlang-core": "workspace:^",
        "@invinite-org/chartlang-runtime": "workspace:^"
    },
    "devDependencies": {
        "esbuild": "^0.24.0",
        "fake-indexeddb": "^6.0.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "engines": {
        "node": ">=20"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/outraday-org/chartlang.git",
        "directory": "packages/host-worker"
    }
}
