{
    "name": "@invinite-org/chartlang-runtime",
    "version": "1.6.0",
    "type": "module",
    "license": "MIT",
    "description": "Execution engine, Series ring buffers, ta.* math primitives",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./internal": {
            "types": "./dist/internal.d.ts",
            "import": "./dist/internal.js"
        }
    },
    "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run --coverage",
        "bench": "vitest bench --run"
    },
    "dependencies": {
        "@invinite-org/chartlang-adapter-kit": "workspace:^",
        "@invinite-org/chartlang-core": "workspace:^"
    },
    "devDependencies": {
        "fast-check": "^3.20.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "engines": {
        "node": ">=20"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/outraday-org/chartlang.git",
        "directory": "packages/runtime"
    }
}
