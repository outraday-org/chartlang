{
    "name": "@invinite-org/chartlang-adapter-kit",
    "version": "1.9.0",
    "type": "module",
    "license": "MIT",
    "description": "SDK for writing chartlang adapters in consumer repos",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./canvas": {
            "types": "./dist/canvas/index.d.ts",
            "import": "./dist/canvas/index.js"
        }
    },
    "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run --coverage"
    },
    "dependencies": {
        "@invinite-org/chartlang-core": "workspace:^"
    },
    "devDependencies": {
        "@types/node": "^20.0.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "engines": {
        "node": ">=20"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/outraday-org/chartlang.git",
        "directory": "packages/adapter-kit"
    }
}
