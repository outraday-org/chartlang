//@version=6
indicator("MASM", overlay=true)
ma_length = input.int(21, "MA Length", options = [8, 21, 30, 50, 100, 200])
mult = input.float(2.0, options = [1.0, 2.0, 3.0])
lt_trend = input(title="LT", defval=close)
smooth = input(14, "Smoothing")
ma = ta.sma(close, ma_length)
sig = ta.sma(lt_trend, smooth)
plot(ma_length == 8 ? ma : sig)
plot(ma * mult)
