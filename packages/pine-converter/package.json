{
    "name": "@invinite-org/chartlang-pine-converter",
    "version": "0.3.0",
    "type": "module",
    "license": "MIT",
    "description": "Pine Script v6 → chartlang source-to-source converter (drawings v1)",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./diagnostics": {
            "types": "./dist/diagnostics/index.d.ts",
            "import": "./dist/diagnostics/index.js"
        }
    },
    "files": ["dist", "fixtures", "README.md", "CHANGELOG.md"],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run --coverage"
    },
    "devDependencies": {
        "@invinite-org/chartlang-compiler": "workspace:*",
        "@invinite-org/chartlang-core": "workspace:*",
        "@types/node": "^20.0.0",
        "fast-check": "^3.20.0",
        "typescript": "^5.6.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=20"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/outraday-org/chartlang.git",
        "directory": "packages/pine-converter"
    }
}
